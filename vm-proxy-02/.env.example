# Nginx Proxy Manager — начальные учётные данные администратора
# После первого входа сменить в UI (Admin > Change Credentials)
NPM_ADMIN_EMAIL=admin@home.loc
NPM_ADMIN_PASSWORD=CHANGE_ME

# Homepage — разрешённые хосты (домен через который открывается дашборд)
# Несколько хостов через запятую: home.home.loc,192.168.1.37:3000
HOMEPAGE_ALLOWED_HOSTS=home.home.loc
