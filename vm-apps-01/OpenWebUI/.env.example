# AFFiNE -> external Postgres on DB server
AFFINE_DB_HOST=10.0.0.20
AFFINE_DB_PORT=5432
AFFINE_DB_NAME=affine
AFFINE_DB_USER=affine
AFFINE_DB_PASSWORD=change-me
AFFINE_SERVER_HOST=0.0.0.0
AFFINE_ADMIN_EMAIL=admin@example.com
AFFINE_ADMIN_PASSWORD=change-me

# AFFiNE Redis (local by default; switch to external Redis if needed)
AFFINE_REDIS_HOST=redis
AFFINE_REDIS_PORT=6379
AFFINE_REDIS_PASSWORD=

# Open Notebook
OPEN_NOTEBOOK_ORIGIN=http://localhost:4110
OPEN_NOTEBOOK_AUTH_SECRET=change-me

# Open Notebook SurrealDB
# For external SurrealDB on DB server set:
# OPEN_NOTEBOOK_SURREAL_URL=ws://<db-server-ip>:8000/rpc
OPEN_NOTEBOOK_SURREAL_URL=ws://surrealdb:8000/rpc
OPEN_NOTEBOOK_SURREAL_NAMESPACE=open-notebook
OPEN_NOTEBOOK_SURREAL_DATABASE=open-notebook
OPEN_NOTEBOOK_SURREAL_USERNAME=root
OPEN_NOTEBOOK_SURREAL_PASSWORD=root
