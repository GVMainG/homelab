# === MeTube ===
# Веб-интерфейс доступен на порту 8081 (http://192.168.1.XX:8081)

# Формат загрузки видео
# bestvideo+bestaudio/best — лучшее видео + лучший звук или лучший файл
# Документация: https://github.com/yt-dlp/yt-dlp#format-selection
YTDL_FORMAT=bestvideo+bestaudio/best

# Формат извлечения звука (mp3, m4a, opus, vorbis, wav, aac)
YTDL_EXTRACT_AUDIO_FORMAT=m4a

# Качество извлекаемого звука в килобитах в секунду
# Допустимые значения: 128, 192, 256, 320
YTDL_EXTRACT_AUDIO_QUALITY=192

# Сохранять оригинальный звук при извлечении аудио (true/false)
YTDL_KEEP_ORIGINAL_AUDIO=false

# Использовать новый движок выбора формата (true/false)
YTDL_PREFER_FFI=false

# === Planka ===
# Веб-интерфейс доступен на порту 3000 (http://192.168.1.XX:3000)

# PostgreSQL в vm-db-01
POSTGRES_HOST=192.168.1.36
POSTGRES_PORT=5432

# Credentials for Planka database (should match vm-db-01 .env)
PLANKA_DB_USER=planka_user
PLANKA_DB_PASSWORD=znz9UWLBiYccNrUxc7t7
PLANKA_DB_NAME=planka

# Planka secret key для шифрования — МЕНЯТЬ НЕЛЬЗЯ после первого запуска
PLANKA_SECRET_KEY=d056b00dcd7e11f819bd74edc8038071e544d3dd36ee522b1d748a5c861523a8231576e9da2b63d6ff2696a704d686de8b16b351ca15905fd42fd3a2f7b453d4

# Разрешить регистрацию новых пользователей (true/false)
