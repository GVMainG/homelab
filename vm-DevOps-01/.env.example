# .env.example — шаблон переменных окружения для vm-DevOps-01
# Скопировать в .env и заполнить значения. Не коммитить .env в git.

# ── Dockhand ─────────────────────────────────────────────────────────────────
# AES-256 ключ для шифрования учётных данных в Dockhand.
# Генерация: openssl rand -base64 32
# setup.sh генерирует это значение автоматически.
ENCRYPTION_KEY=CHANGE_ME

# UID/GID пользователя, от имени которого запускается Dockhand (опционально).
# По умолчанию: 1000/1000. Узнать свой: id -u && id -g
PUID=1000
PGID=1000

# ── Homepage ─────────────────────────────────────────────────────────────────
# Дашборд со ссылками на все сервисы.
# :3001 — веб-UI (http://192.168.1.XX:3001)
# Конфиги: config/services.yml, config/settings.yml, config/bookmarks.yml
# Доступен через NPM: https://homepage.gv-services.net.ru
